<!DOCTYPE html>
<html lang="en-US">
<head>
  <!-- Analytics code goes here -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My LinkSprout</title>
  <link rel="stylesheet" href="linksprout.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Sansita+Swashed:wght@600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <script>
    var sites = [
      'http://www.yourproject1.com',
      'https://yourproject2.com'
    ];

    function randomSite(el) {
      var i = Math.floor(Math.random() * sites.length);
      el.href = sites[i];
    }
  </script>
</head>
<body>
  <div class="container">

    <div class="profile">
